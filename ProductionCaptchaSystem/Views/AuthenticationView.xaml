<Page x:Class="ProductionCaptchaSystem.Views.AuthenticationView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Вход в систему">

    <Grid Background="White">
        <!-- Чуть шире и выше, чтобы всё влезало -->
        <Border Width="540" Height="640"
                Background="White"
                BorderBrush="#2196F3"
                BorderThickness="2"
                CornerRadius="10"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">

            <Grid Margin="30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Заголовок -->
                    <RowDefinition Height="Auto"/>
                    <!-- Логин -->
                    <RowDefinition Height="Auto"/>
                    <!-- Пароль -->
                    <RowDefinition Height="Auto"/>
                    <!-- Текст капчи -->
                    <RowDefinition Height="Auto"/>
                    <!-- Область капчи -->
                    <RowDefinition Height="Auto"/>
                    <!-- Кнопка -->
                    <RowDefinition Height="Auto"/>
                    <!-- Подсказка (если нужна) -->
                </Grid.RowDefinitions>

                <!-- Заголовок -->
                <TextBlock Grid.Row="0"
                           Text="Авторизация"
                           FontSize="24"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Foreground="#2196F3"
                           Margin="0,0,0,20"/>

                <!-- Логин -->
                <StackPanel Grid.Row="1" Margin="0,0,0,10">
                    <TextBlock Text="Логин:" FontSize="14" Margin="0,0,0,5"/>
                    <TextBox x:Name="UsernameTextBox"
                             Height="35"
                             FontSize="14"
                             Padding="10,8"/>
                </StackPanel>

                <!-- Пароль -->
                <StackPanel Grid.Row="2" Margin="0,0,0,10">
                    <TextBlock Text="Пароль:" FontSize="14" Margin="0,0,0,5"/>
                    <PasswordBox x:Name="PasswordBox"
                                 Height="35"
                                 FontSize="14"
                                 Padding="10,8"/>
                </StackPanel>

                <!-- Текст капчи -->
                <TextBlock Grid.Row="3"
                           Text="Соберите капчу, поворачивая фрагменты:"
                           FontSize="14"
                           Margin="0,0,0,8"/>

                <!-- Область капчи: ровный квадрат 2x2 -->
                <Border Grid.Row="4"
                        Width="260" Height="260"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        BorderBrush="#DDDDDD"
                        BorderThickness="1"
                        Margin="0,0,0,20">
                    <UniformGrid Rows="2" Columns="2">
                        <Image x:Name="Part1"
                               Source="pack://application:,,,/ProductionCaptchaSystem;component/Assets/1-8.png"
                               Stretch="Fill"
                               RenderTransformOrigin="0.5,0.5"
                               MouseLeftButtonDown="CaptchaPiece_OnMouseLeftButtonDown">
                            <Image.RenderTransform>
                                <RotateTransform Angle="0"/>
                            </Image.RenderTransform>
                        </Image>

                        <Image x:Name="Part2"
                               Source="pack://application:,,,/ProductionCaptchaSystem;component/Assets/2-9.png"
                               Stretch="Fill"
                               RenderTransformOrigin="0.5,0.5"
                               MouseLeftButtonDown="CaptchaPiece_OnMouseLeftButtonDown">
                            <Image.RenderTransform>
                                <RotateTransform Angle="0"/>
                            </Image.RenderTransform>
                        </Image>

                        <Image x:Name="Part3"
                               Source="pack://application:,,,/ProductionCaptchaSystem;component/Assets/3-10.png"
                               Stretch="Fill"
                               RenderTransformOrigin="0.5,0.5"
                               MouseLeftButtonDown="CaptchaPiece_OnMouseLeftButtonDown">
                            <Image.RenderTransform>
                                <RotateTransform Angle="0"/>
                            </Image.RenderTransform>
                        </Image>

                        <Image x:Name="Part4"
                               Source="pack://application:,,,/ProductionCaptchaSystem;component/Assets/4-7.png"
                               Stretch="Fill"
                               RenderTransformOrigin="0.5,0.5"
                               MouseLeftButtonDown="CaptchaPiece_OnMouseLeftButtonDown">
                            <Image.RenderTransform>
                                <RotateTransform Angle="0"/>
                            </Image.RenderTransform>
                        </Image>
                    </UniformGrid>
                </Border>

                <!-- Кнопка входа -->
                <Button Grid.Row="5"
                        Content="Войти"
                        Height="40"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Background="#2196F3"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="LoginButton_OnClick"
                        HorizontalAlignment="Stretch"/>

                <!-- Подсказка (по желанию)
                <TextBlock Grid.Row="6"
                           Text="Тестовые данные: admin/111 или user/111"
                           FontSize="11"
                           Foreground="Gray"
                           HorizontalAlignment="Center"
                           Margin="0,10,0,0"/>
                -->
            </Grid>
        </Border>
    </Grid>
</Page>

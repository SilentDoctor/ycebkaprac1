<Page x:Class="ProductionCaptchaSystem.Views.AuthenticationView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Вход в систему">

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#1E1E2E" Offset="0"/>
                <GradientStop Color="#2D1B69" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Border Width="460"
                VerticalAlignment="Center" HorizontalAlignment="Center"
                CornerRadius="16">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#2A2A3E" Offset="0"/>
                    <GradientStop Color="#1E1E2E" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect Color="#7C6AF7" BlurRadius="30" Opacity="0.3" ShadowDepth="0"/>
            </Border.Effect>

            <StackPanel Margin="36,28,36,28">

                <!-- Заголовок -->
                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,18">
                    <TextBlock Text="🔐" FontSize="30" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                    <TextBlock Text="Вход в систему" FontSize="20" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center"/>
                    <TextBlock Text="Система управления производством"
                               FontSize="11" Foreground="#7070A0"
                               HorizontalAlignment="Center" Margin="0,3,0,0"/>
                </StackPanel>

                <!-- Логин -->
                <StackPanel Margin="0,0,0,10">
                    <TextBlock Text="Логин" FontSize="12" Foreground="#A0A0C0" Margin="0,0,0,5"/>
                    <Border Background="#1A1A2E" CornerRadius="8" Padding="12,0">
                        <TextBox x:Name="UsernameTextBox" Height="36" FontSize="14"
                                 Background="Transparent" Foreground="White"
                                 BorderThickness="0" VerticalContentAlignment="Center"/>
                    </Border>
                </StackPanel>

                <!-- Пароль -->
                <StackPanel Margin="0,0,0,14">
                    <TextBlock Text="Пароль" FontSize="12" Foreground="#A0A0C0" Margin="0,0,0,5"/>
                    <Border Background="#1A1A2E" CornerRadius="8" Padding="12,0">
                        <PasswordBox x:Name="PasswordBox" Height="36" FontSize="14"
                                     Background="Transparent" Foreground="White"
                                     BorderThickness="0" VerticalContentAlignment="Center"/>
                    </Border>
                </StackPanel>

                <!-- Подпись капчи -->
                <TextBlock Text="Поверните фрагменты изображения в правильное положение:"
                           FontSize="12" Foreground="#A0A0C0"
                           TextWrapping="Wrap" Margin="0,0,0,8"/>

                <!-- Капча 200x200 -->
                <Border Width="200" Height="200" HorizontalAlignment="Center"
                        CornerRadius="8" Margin="0,0,0,16">
                    <Border.Effect>
                        <DropShadowEffect Color="#000" BlurRadius="12" Opacity="0.4" ShadowDepth="2"/>
                    </Border.Effect>
                    <UniformGrid Rows="2" Columns="2">
                        <Image x:Name="Part1"
                               Source="pack://application:,,,/ProductionCaptchaSystem;component/Assets/1-8.png"
                               Stretch="Fill" RenderTransformOrigin="0.5,0.5"
                               MouseLeftButtonDown="CaptchaPiece_OnMouseLeftButtonDown" Cursor="Hand">
                            <Image.RenderTransform>
                                <RotateTransform Angle="0"/>
                            </Image.RenderTransform>
                        </Image>
                        <Image x:Name="Part2"
                               Source="pack://application:,,,/ProductionCaptchaSystem;component/Assets/2-9.png"
                               Stretch="Fill" RenderTransformOrigin="0.5,0.5"
                               MouseLeftButtonDown="CaptchaPiece_OnMouseLeftButtonDown" Cursor="Hand">
                            <Image.RenderTransform>
                                <RotateTransform Angle="0"/>
                            </Image.RenderTransform>
                        </Image>
                        <Image x:Name="Part3"
                               Source="pack://application:,,,/ProductionCaptchaSystem;component/Assets/3-10.png"
                               Stretch="Fill" RenderTransformOrigin="0.5,0.5"
                               MouseLeftButtonDown="CaptchaPiece_OnMouseLeftButtonDown" Cursor="Hand">
                            <Image.RenderTransform>
                                <RotateTransform Angle="0"/>
                            </Image.RenderTransform>
                        </Image>
                        <Image x:Name="Part4"
                               Source="pack://application:,,,/ProductionCaptchaSystem;component/Assets/4-7.png"
                               Stretch="Fill" RenderTransformOrigin="0.5,0.5"
                               MouseLeftButtonDown="CaptchaPiece_OnMouseLeftButtonDown" Cursor="Hand">
                            <Image.RenderTransform>
                                <RotateTransform Angle="0"/>
                            </Image.RenderTransform>
                        </Image>
                    </UniformGrid>
                </Border>

                <!-- Кнопка войти -->
                <Button Content="Войти →" Height="42" FontSize="15" FontWeight="Bold"
                        Foreground="White" BorderThickness="0" Cursor="Hand"
                        Click="LoginButton_OnClick">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#7C6AF7" Offset="0"/>
                            <GradientStop Color="#00C896" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>

            </StackPanel>
        </Border>
    </Grid>
</Page>

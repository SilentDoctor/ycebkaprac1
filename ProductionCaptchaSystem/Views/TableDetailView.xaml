<Page x:Class="ProductionCaptchaSystem.Views.TableDetailView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Таблица">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TableTitle"
                   Grid.Row="0"
                   FontSize="20"
                   FontWeight="Bold"
                   Foreground="#2196F3"
                   Margin="10"/>

        <DataGrid x:Name="TableGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="True"
                  IsReadOnly="True"
                  Margin="10"/>

        <Button Grid.Row="2"
                Content="← Назад"
                Width="120"
                Height="35"
                HorizontalAlignment="Left"
                Background="#2196F3"
                Foreground="White"
                BorderThickness="0"
                Margin="10"
                Click="BackButton_Click"/>
    </Grid>
</Page>

<Page x:Class="ProductionCaptchaSystem.Views.TableSelectionView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Выбор таблицы">

    <Grid Background="White">
        <Border Width="500" Height="450"
                Background="White"
                BorderBrush="#2196F3"
                BorderThickness="2"
                CornerRadius="10"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">

            <StackPanel Margin="40" VerticalAlignment="Center">
                <TextBlock Text="Просмотр таблиц" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           HorizontalAlignment="Center"
                           Foreground="#2196F3"
                           Margin="0,0,0,30"/>

                <Button Content="Заказчики" 
                        Height="50" 
                        FontSize="16"
                        Background="#2196F3"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Margin="0,0,0,10"
                        Click="ShowCustomers_Click"/>

                <Button Content="Заказы покупателей" 
                        Height="50" 
                        FontSize="16"
                        Background="#2196F3"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Margin="0,0,0,10"
                        Click="ShowOrders_Click"/>

                <Button Content="Продукция" 
                        Height="50" 
                        FontSize="16"
                        Background="#2196F3"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Margin="0,0,0,10"
                        Click="ShowProducts_Click"/>

                <Button Content="Цены" 
                        Height="50" 
                        FontSize="16"
                        Background="#2196F3"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Margin="0,0,0,10"
                        Click="ShowPrices_Click"/>

                <Button Content="Спецификация" 
                        Height="50" 
                        FontSize="16"
                        Background="#2196F3"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Margin="0,0,0,10"
                        Click="ShowSpecification_Click"/>

                <Button Content="← Назад" 
                        Height="40" 
                        FontSize="14"
                        Background="#999"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Margin="0,20,0,0"
                        Click="BackButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>

<Page x:Class="ProductionCaptchaSystem.Views.CostCalculationView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Расчёт стоимости">

	<Page.Resources>
		<!-- Стиль для ComboBox — тёмный выпадающий список -->
		<Style TargetType="ComboBox">
			<Setter Property="Background" Value="#2A2A3E"/>
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="BorderBrush" Value="#3A3A5E"/>
			<Setter Property="BorderThickness" Value="1"/>
		</Style>
		<Style TargetType="ComboBoxItem">
			<Setter Property="Background" Value="#2A2A3E"/>
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="Padding" Value="10,6"/>
			<Style.Triggers>
				<Trigger Property="IsHighlighted" Value="True">
					<Setter Property="Background" Value="#7C6AF7"/>
					<Setter Property="Foreground" Value="White"/>
				</Trigger>
				<Trigger Property="IsSelected" Value="True">
					<Setter Property="Background" Value="#3A3A5E"/>
					<Setter Property="Foreground" Value="White"/>
				</Trigger>
			</Style.Triggers>
		</Style>
	</Page.Resources>

	<Grid Background="#1E1E2E">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<StackPanel Grid.Row="0" Margin="20,20,20,15">
			<TextBlock Text="📦 Расчёт себестоимости"
                       FontSize="22" FontWeight="Bold" Foreground="#E0E0FF"/>
			<TextBlock Text="Выберите продукт для просмотра состава и стоимости"
                       FontSize="12" Foreground="#7070A0" Margin="0,4,0,0"/>
		</StackPanel>

		<Border Grid.Row="1" Background="#2A2A3E" Margin="20,0,20,15" CornerRadius="10" Padding="15">
			<StackPanel Orientation="Horizontal">
				<TextBlock Text="Продукт:" Foreground="#A0A0C0"
                           VerticalAlignment="Center" Margin="0,0,12,0" FontSize="14"/>
				<ComboBox x:Name="ProductComboBox" Width="280" Height="36"
                          SelectionChanged="ProductComboBox_SelectionChanged"
                          DisplayMemberPath="Name" FontSize="14"/>
				<Button Content="▶ Рассчитать" Margin="15,0,0,0"
                        Height="36" Padding="16,0"
                        Background="#00C896" Foreground="White"
                        BorderThickness="0" FontSize="13" FontWeight="SemiBold"
                        Cursor="Hand" Click="CalculateButton_Click"/>
			</StackPanel>
		</Border>

		<Border Grid.Row="2" Background="#2A2A3E" Margin="20,0,20,15" CornerRadius="10">
			<DataGrid x:Name="MaterialsDataGrid" AutoGenerateColumns="False"
                      IsReadOnly="True" Background="Transparent"
                      Foreground="#E0E0FF" BorderThickness="0"
                      RowBackground="#1E1E2E" AlternatingRowBackground="#252535"
                      GridLinesVisibility="Horizontal">
				<DataGrid.ColumnHeaderStyle>
					<Style TargetType="DataGridColumnHeader">
						<Setter Property="Background" Value="#3A3A5E"/>
						<Setter Property="Foreground" Value="#A0A0C0"/>
						<Setter Property="Padding" Value="12,8"/>
						<Setter Property="FontWeight" Value="SemiBold"/>
					</Style>
				</DataGrid.ColumnHeaderStyle>
				<DataGrid.Columns>
					<DataGridTextColumn Header="Материал" Binding="{Binding MaterialName}" Width="*"/>
					<DataGridTextColumn Header="Ед. изм." Binding="{Binding Unit}" Width="80"/>
					<DataGridTextColumn Header="Количество" Binding="{Binding Quantity, StringFormat=N2}" Width="110"/>
					<DataGridTextColumn Header="Цена, руб." Binding="{Binding Price, StringFormat=N2}" Width="110"/>
					<DataGridTextColumn Header="Стоимость, руб." Binding="{Binding Cost, StringFormat=N2}" Width="130"/>
				</DataGrid.Columns>
			</DataGrid>
		</Border>

		<Border Grid.Row="3" Background="#2A2A3E" Margin="20,0,20,20" CornerRadius="10" Padding="20,14">
			<DockPanel>
				<TextBlock Text="Итого себестоимость:" FontSize="16"
                           FontWeight="Bold" Foreground="#E0E0FF" VerticalAlignment="Center"/>
				<TextBlock x:Name="TotalCostText" Text="0.00 руб."
                           FontSize="18" FontWeight="Bold" Foreground="#00C896"
                           Margin="12,0,0,0" VerticalAlignment="Center"
                           HorizontalAlignment="Right" DockPanel.Dock="Right"/>
			</DockPanel>
		</Border>
	</Grid>
</Page>

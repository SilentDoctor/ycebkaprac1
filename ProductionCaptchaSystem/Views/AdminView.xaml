<Page x:Class="ProductionCaptchaSystem.Views.AdminView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Панель администратора">

    <Grid Background="#1E1E2E">
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Border Grid.Row="0" Background="#2A2A3E" Padding="20,0">
            <DockPanel>
                <TextBlock Text="⚙ Панель администратора"
                           FontSize="22" FontWeight="Bold"
                           Foreground="#E0E0FF"
                           VerticalAlignment="Center"
                           DockPanel.Dock="Left"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="📥 Импорт" Width="120" Height="36"
                            Background="#00C896" Foreground="White"
                            BorderThickness="0" FontSize="13" Cursor="Hand"
                            Click="ImportButton_OnClick" Margin="5,0"/>
                    <Button Content="👥 Пользователи" Width="140" Height="36"
                            Background="#7C6AF7" Foreground="White"
                            BorderThickness="0" FontSize="13" Cursor="Hand"
                            Click="UsersButton_OnClick" Margin="5,0"/>
                    <Button Content="📊 Таблицы" Width="120" Height="36"
                            Background="#F97316" Foreground="White"
                            BorderThickness="0" FontSize="13" Cursor="Hand"
                            Click="ViewTablesButton_OnClick" Margin="5,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Контент -->
        <Border Grid.Row="1" Margin="20" Background="#2A2A3E"
                CornerRadius="12" Padding="20">
            <Grid>
                <DataGrid x:Name="UsersDataGrid"
                          Visibility="Collapsed"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          SelectionMode="Single"
                          Background="Transparent"
                          Foreground="#E0E0FF"
                          BorderThickness="0"
                          RowBackground="#1E1E2E"
                          AlternatingRowBackground="#252535"
                          GridLinesVisibility="None">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#7C6AF7"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="Padding" Value="10,6"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                        <DataGridTextColumn Header="Логин" Binding="{Binding Username}" Width="150"/>
                        <DataGridCheckBoxColumn Header="Админ" Binding="{Binding IsAdmin}" Width="80"/>
                        <DataGridCheckBoxColumn Header="Заблокирован" Binding="{Binding IsBlocked}" Width="120"/>
                        <DataGridTextColumn Header="Дата создания" Binding="{Binding CreatedAt}" Width="150"/>
                    </DataGrid.Columns>
                </DataGrid>

                <ScrollViewer x:Name="ImportLogScroll"
                              Visibility="Visible"
                              VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="ImportLogTextBlock"
                               FontFamily="Consolas" FontSize="13"
                               Foreground="#A0A0C0" TextWrapping="Wrap"
                               Text="Нажмите 'Импорт' для загрузки файлов из папки Data/"/>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Page>

<Page x:Class="ProductionCaptchaSystem.Views.UserView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Панель пользователя">

    <Grid Background="#F5F5F5">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="400">
            <TextBlock Text="Панель пользователя" 
                       FontSize="32" 
                       FontWeight="Bold"
                       Foreground="#2196F3"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,40"/>

            <TextBlock Text="Модули 3 и 6" 
                       FontSize="16"
                       HorizontalAlignment="Center"
                       Foreground="#666"
                       Margin="0,0,0,20"/>

            <!-- Модуль 6: REST API -->
            <Button Content="🎲 Получить случайное имя" 
                    Height="50" 
                    FontSize="16"
                    FontWeight="SemiBold"
                    Background="#FF4081"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="GetRandomNameButton_OnClick"
                    Margin="0,0,0,10"/>

            <!-- Модуль 3: расчёт стоимости -->
            <Button Content="📊 Расчёт стоимости продукции"
                    Height="40"
                    FontSize="14"
                    Background="#4CAF50"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="OpenCostCalculationButton_OnClick"
                    Margin="0,0,0,20"/>

            <Border Background="White" 
                    BorderBrush="#DDDDDD" 
                    BorderThickness="1"
                    CornerRadius="5"
                    Padding="20"
                    MinHeight="100">
                <TextBlock x:Name="ResultTextBlock"
                           Text="Нажмите кнопку для получения случайного имени"
                           FontSize="14"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="#333"/>
            </Border>
        </StackPanel>
    </Grid>
</Page>
